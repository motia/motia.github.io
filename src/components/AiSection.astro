---
import type { PortfolioData } from '../data/schema';
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';
const { ai } = Astro.props as { ai: PortfolioData['aiSection'] };
---
<section id="ai">
  <div class="container">
    <SectionHeading label={ai.label} title={ai.title} subtitle={ai.subtitle} />
    <div class="ai-layout">
      <div class="ai-left">
        <div class="ai-pipeline">
          {ai.pipeline.map((step, index) => (
            <>
              <div class="pip-step" data-a>
                <span class="pip-num">{step.number}</span>
                <Icon name={step.icon} class="pip-icon" />
                <div><div class="pip-label">{step.label}</div><div class="pip-desc">{step.description}</div></div>
              </div>
              {index < ai.pipeline.length - 1 && <div class="pip-arrow">↓</div>}
            </>
          ))}
        </div>
      </div>
      <div class="ai-right">
        <div class="ai-honest-box">
          <div class="aih-label">{ai.strengthsLabel}</div>
          <ul class="aih-strong">
            {ai.strengths.map((item) => <li>{item}</li>)}
          </ul>
          <div class="aih-learning">
            <div style="font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;font-weight:600;">{ai.deepeningLabel}</div>
            <ul>
              {ai.deepening.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
        <div style="padding:20px;background:var(--bg2);border:1px solid var(--border);border-top:none;border-radius:0 0 2px 2px;">
          <p style="font-size:12.5px;color:var(--text3);line-height:1.7;font-style:italic;">“{ai.quote}”</p>
        </div>
      </div>
    </div>
  </div>
</section>
