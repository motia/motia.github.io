---
import type { PortfolioData } from '../data/schema';
import Icon from './Icon.astro';
const { availability } = Astro.props as { availability: PortfolioData['availability'] };
---
<section id="availability">
  <div class="container">
    <div class="availability-card" data-a>
      <div class="availability-copy">
        <div class="avail"><span class="avail-dot"></span>{availability.eyebrow}</div>
        <h2 class="availability-title">{availability.title.prefix} <strong>{availability.title.strong}</strong></h2>
        <p class="availability-desc">{availability.description}</p>
      </div>
      <div class="availability-links contact-links">
        {availability.links.map((link) => {
          const iconName = link.icon ?? link.type;
          const inner = <><Icon name={iconName} class="cl-icon" /><div class="cl-info"><div class="cl-label">{link.label}</div><div class="cl-value">{link.value}</div></div></>;
          return link.href
            ? <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined} class="cl">{inner}</a>
            : <div class="cl" style="cursor:default;">{inner}</div>;
        })}
      </div>
    </div>
  </div>
</section>
