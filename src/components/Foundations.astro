---
import type { PortfolioData } from '../data/schema';

const { foundations } = Astro.props as { foundations: PortfolioData['foundations'] };
---

<section id="foundations" class="foundations-section">
  <div class="foundations-container">
    <header class="foundations-header">
      <div class="sec-label">{foundations.eyebrow}</div>
      <div>
        <h2 class="sec-title">
          {foundations.title.split(',')[0]} <em>{foundations.title.split(',').slice(1).join(',').trim()}</em>
        </h2>
        <p class="foundations-description">{foundations.description}</p>
      </div>
    </header>

    <div class="foundations-grid">
      <div class="foundations-main">
        {foundations.education.map((item) => (
          <article class="education-card" data-a>
            <div class="education-period">{item.period}</div>
            <div class="education-body">
              <h3>{item.degree}</h3>
              <p class="education-school">{item.school}</p>
              <ul>
                {item.details.map((detail) => <li>{detail}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <aside class="foundations-side">
        <div class="recognition-card" data-a>
          <div class="side-label">Recognition</div>
          {foundations.recognition.map((item) => (
            <div class="recognition-item">
              <strong>{item.title}</strong>
              <span>{item.meta}</span>
            </div>
          ))}
        </div>

        <div class="coursework-card" data-a>
          <div class="side-label">Selected technical foundation</div>
          <div class="coursework-list">
            {foundations.coursework.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .foundations-section {
    background:
      radial-gradient(circle at 84% 10%, rgba(217, 119, 6, 0.08), transparent 34rem),
      var(--bg);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .foundations-container {
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding: 96px 0;
  }

  .foundations-header {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 40px;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--border);
  }

  .foundations-description {
    max-width: 620px;
    margin-top: 24px;
    color: var(--text2);
    font-size: 1rem;
    line-height: 1.8;
  }

  .foundations-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 56px;
    padding-top: 56px;
  }

  .foundations-main {
    display: grid;
    border-top: 1px solid var(--border);
  }

  .education-card {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
  }

  .education-period, .side-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text3);
  }

  .education-body h3 {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2vw, 2rem);
    line-height: 1.05;
    color: var(--text);
  }

  .education-school {
    margin-top: 8px;
    color: var(--accent);
    font-size: 0.92rem;
  }

  .education-body ul {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    padding: 0;
    list-style: none;
  }

  .education-body li {
    position: relative;
    padding-left: 18px;
    color: var(--text2);
    line-height: 1.65;
  }

  .education-body li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
  }

  .foundations-side {
    display: grid;
    align-content: start;
    gap: 16px;
  }

  .recognition-card,
  .coursework-card {
    border: 1px solid var(--border);
    background: rgba(245, 240, 232, 0.025);
    padding: 28px;
  }

  .recognition-item {
    display: grid;
    gap: 6px;
    margin-top: 18px;
  }

  .recognition-item strong {
    font-family: var(--font-serif);
    font-size: 1.45rem;
    line-height: 1.1;
    color: var(--text);
  }

  .recognition-item span {
    color: var(--text2);
    font-size: 0.92rem;
  }

  .coursework-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .coursework-list span {
    border: 1px solid var(--border-accent);
    background: var(--accent-soft);
    color: var(--accent2);
    padding: 6px 10px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1;
    letter-spacing: 0.04em;
  }

  @media (max-width: 860px) {
    .foundations-container {
      width: min(100% - 32px, 1120px);
      padding: 72px 0;
    }

    .foundations-header,
    .foundations-grid,
    .education-card {
      grid-template-columns: 1fr;
    }

    .foundations-header {
      gap: 20px;
      padding-bottom: 40px;
    }

    .foundations-grid {
      gap: 32px;
      padding-top: 40px;
    }

    .education-card {
      gap: 12px;
      padding: 28px 0;
    }
  }
</style>
