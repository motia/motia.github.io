---
import type { LifecycleEntry } from '../data/site-structure';
const { lifecycle } = Astro.props as { lifecycle: readonly LifecycleEntry[] };
---
<div class="lifecycle-bar">
  <div class="lifecycle-inner">
    {lifecycle.map((item, index) => (
      <div class={`stage-tab ${index === 0 ? 'active' : ''}`}>
        <span class="stage-num">{item.number}</span>
        <span class="stage-name">{item.name}</span>
        <span class="stage-desc">{item.description}</span>
      </div>
    ))}
  </div>
</div>
